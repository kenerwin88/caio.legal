{
  "name": "caio-legal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "test": "node --test",
    "images:articles": "node scripts/generate-article-images.mjs",
    "build": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir .ssr-dist && node scripts/prerender.mjs",
    "preview": "vite preview",
    "verify:build": "node scripts/verify-build.mjs",
    "check": "npm run lint && npm test && npm run build && npm run verify:build"
  },
  "dependencies": {
    "markdown-to-jsx": "9.9.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "24.10.10",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "sharp": "^0.35.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5"
  }
}
